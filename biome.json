{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "files": {
    "includes": ["packages/**/src/**/*.ts"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noDuplicateTestHooks": "off",
        "noExplicitAny": "off"
      }
    }
  },
  "formatter": {
    "enabled": true
  }
}
